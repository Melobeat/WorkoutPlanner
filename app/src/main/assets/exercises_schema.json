{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Exercises List",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "name": { "type": "string" },
      "muscleGroup": { "type": "string" },
      "description": { "type": "string" },
      "equipmentId": { "type": ["string", "null"] }
