{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Equipment List",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string" },
      "defaultWeight": { "type": "number" },
      "weightStep": { "type": "number" }
    },
    "required": ["id", "name"]
  }
}
